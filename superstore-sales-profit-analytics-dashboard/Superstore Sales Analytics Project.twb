      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1ncq3b51rtat471ezg2cc1oqcfu0].[cnt:Order ID:qk]&quot;' value='Total_Orders' />
        </aliases>
      </column>
      <column caption='Profit_Margin' datatype='real' name='[Calculation_0082193476780034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Average_Order_Value' datatype='real' name='[Calculation_0082193478209539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Order ID])' />
      </column>
      <column caption='Highest_monthly_sales' datatype='string' name='[Calculation_1365048987070464]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) = WINDOW_MAX(SUM([Sales]))&#13;&#10;THEN &quot;Highest&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Order_Frequency' datatype='integer' name='[Calculation_1365049055776786]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer ID] : COUNTD([Order ID]) }' />
      </column>
      <column caption='Total_Revenue' datatype='real' name='[Calculation_1365049108832275]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])/SUM([Quantity])' />
      </column>
      <column caption='Repeat_Customer' datatype='string' name='[Calculation_1365049110450196]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [Customer ID] : COUNT([Order ID]) } &gt; 1&#13;&#10;THEN [Customer ID]&#13;&#10;END' />
      </column>
      <column caption='Customer_Retention' datatype='real' name='[Calculation_1365049111535637]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNTD([Calculation_1365049110450196])&#13;&#10;/&#13;&#10;COUNTD([Customer ID])' />
      </column>
      <column caption='Avg_Customer_Spend' datatype='real' name='[Calculation_1365049336066070]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Customer ID])' />
      </column>
